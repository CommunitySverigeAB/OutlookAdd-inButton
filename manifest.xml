<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:version="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
  xsi:type="MailApp">

  <Id>d70a18a8-9705-4fe1-8a07-ab1c9aa8b3ee</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Contoso</ProviderName>
  <DefaultLocale>sv-SE</DefaultLocale>
  <DisplayName DefaultValue="Beställning (delad brevlåda)"/>
  <Description DefaultValue="Lägger till kategorin Beställning och flaggar mailet."/>
  <IconUrl DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/assets/icon-128.png"/>
  <!-- Lägg in en supportlänk (krävs av valideraren) -->
  <SupportUrl DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <!-- Kravnivå för moderna API:er i Nya Outlook/OWA -->
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.13"/>
    </Sets>
  </Requirements>

  <!-- WERK: FormSettings måste finnas och komma FÖRE <Permissions>.
       SourceLocation kan peka på samma taskpane.html du använder i kommandot. -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- Behörighet: ReadWriteMailbox om du ev. skapar kategorin i masterlistan -->
  <Permissions>ReadWriteMailbox</Permissions>

  <!-- Aktiveras på e-post i läsläge -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <!-- SSO: Se till att denna domän matchar alla resurser.
       Ingen trailing slash i Resource. -->
  <WebApplicationInfo>
    <Id>8d7be25b-0788-44d7-8575-1fcdd6ee79c2</Id>
    <Resource>api://communitysverigeab.github.io/OutlookAdd-inButton</Resource>
    <Scopes>
      <Scope>Mail.ReadWrite</Scope>
      <Scope>openid</Scope>
      <Scope>profile</Scope>
      <Scope>email</Scope>
      <Scope>offline_access</Scope>
    </Scopes>
  </WebApplicationInfo>

  <!-- Kommandon + shared mailbox-stöd -->
  <VersionOverrides xsi:type="version:VersionOverrides" Version="1.0">
    <version:Hosts>
      <version:Host xsi:type="version:MailHost">
        <version:DesktopFormFactor>

          <!-- Viktigt för delade brevlådor -->
          <version:SupportsSharedFolders>true</version:SupportsSharedFolders>

          <version:ExtensionPoint xsi:type="version:MessageReadCommandSurface">
            <version:OfficeTab id="TabDefault">
              <version:Group id="grpOrder" label="Beställning">

                <!-- Öppna panel (valfritt) -->
                <version:Control xsi:type="version:Button" id="openPane">
                  <version:Label resid="lblOpenPane"/>
                  <version:Supertip>
                    <version:Title resid="lblOpenPane"/>
                    <version:Description resid="tipOpenPane"/>
                  </version:Supertip>
                  <version:Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </version:Icon>
                  <version:Action xsi:type="version:ShowTaskpane">
                    <version:SourceLocation resid="taskpaneUrl"/>
                  </version:Action>
                </version:Control>

                <!-- Huvudknappen: kategori + flagga -->
                <version:Control xsi:type="version:Button" id="orderAndFlag">
                  <version:Label resid="lblOrder"/>
                  <version:Supertip>
                    <version:Title resid="lblOrder"/>
                    <version:Description resid="tipOrder"/>
                  </version:Supertip>
                  <version:Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </version:Icon>
                  <version:Action xsi:type="version:ExecuteFunction">
                    <version:FunctionName>setOrderCategoryAndFlag</version:FunctionName>
                  </version:Action>
                </version:Control>

              </version:Group>
            </version:OfficeTab>
          </version:ExtensionPoint>

          <!-- FunctionFile måste peka på samma domän som Resource -->
          <version:FunctionFile resid="functionsUrl"/>

        </version:DesktopFormFactor>
      </version:Host>
    </version:Hosts>

    <version:Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/assets/icon-16.png"/>
        <bt:Image id="Icon32" DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/assets/icon-32.png"/>
        <bt:Image id="Icon80" DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/assets/icon-80.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="taskpaneUrl"  DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/taskpane.html"/>
        <bt:Url id="functionsUrl" DefaultValue="https://communitysverigeab.github.io/OutlookAdd-inButton/commands.html"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="lblOpenPane" DefaultValue="Öppna panel"/>
        <bt:String id="lblOrder"    DefaultValue="Beställning + flagga"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="tipOpenPane" DefaultValue="Öppnar tilläggets panel."/>
        <bt:String id="tipOrder"    DefaultValue="Lägger till kategorin Beställning och flaggar meddelandet."/>
      </bt:LongStrings>
    </version:Resources>
  </VersionOverrides>
</OfficeApp>
